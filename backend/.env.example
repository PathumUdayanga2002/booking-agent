PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/hotel_booking
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
TEMP_ADMIN_KEY=register-admin-once
FRONTEND_ORIGIN=http://localhost:3000

# Email Configuration (SMTP)
# Supports Gmail, Outlook, SendGrid, etc.
# For Gmail: Use "App Password" (generate from myaccount.google.com/apppasswords)
# For SendGrid: Use "apikey" as user and API key as password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@aurevia-hotel.com
SMTP_FROM_NAME=Aurevia Hotel Booking
