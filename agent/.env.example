# FastAPI Server Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_ENV=development

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=hotel_booking
MONGO_COLLECTION_CONVERSATIONS=agent_conversations

# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=hotel_knowledge
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Express Backend Configuration (for API calls)
EXPRESS_HOST=localhost
EXPRESS_PORT=5000
EXPRESS_BACKEND_URL=http://localhost:5000
EXPRESS_ADMIN_TOKEN=your_admin_token_here

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256

# Document Processing Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Logging Configuration
LOG_LEVEL=INFO

# WebSocket Configuration
WEBSOCKET_HEARTBEAT_INTERVAL=30
